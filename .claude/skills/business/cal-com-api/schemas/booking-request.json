{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Booking Request",
  "description": "Request payload for creating a booking via Cal.com API v2",
  "type": "object",
  "version": "2.1.0",
  "required": [
    "start",
    "attendee"
  ],
  "properties": {
    "start": {
      "type": "string",
      "format": "date-time",
      "description": "UTC start time in ISO 8601 format (e.g., 2026-07-20T14:00:00Z)"
    },
    "attendee": {
      "type": "object",
      "required": [
        "name",
        "email",
        "timeZone"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Attendee full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Attendee email address"
        },
        "timeZone": {
          "type": "string",
          "pattern": "^[A-Za-z_]+/[A-Za-z_]+$",
          "description": "IANA timezone identifier (e.g., America/Los_Angeles, Europe/London)"
        },
        "phoneNumber": {
          "type": "string",
          "pattern": "^\\+?[1-9]\\d{1,14}$",
          "description": "E.164 format phone number for SMS notifications (optional)"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "ISO 639-1 language code (e.g., en, en-US, fr-FR)"
        },
        "metadata": {
          "type": "object",
          "description": "Custom metadata for the attendee",
          "additionalProperties": true
        }
      }
    },
    "eventTypeId": {
      "type": "integer",
      "minimum": 1,
      "description": "Numeric ID of the event type (mutually exclusive with eventTypeSlug)"
    },
    "eventTypeSlug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slug of the event type (requires username/teamSlug/orgSlug)"
    },
    "username": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$",
      "description": "Username for event type slug lookup (individual or team)"
    },
    "organizationSlug": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$",
      "description": "Organization slug for org-scoped event types"
    },
    "responses": {
      "type": "object",
      "description": "Answers to custom booking form fields",
      "additionalProperties": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Custom metadata for the booking (supports idempotencyKey)",
      "additionalProperties": true,
      "properties": {
        "idempotencyKey": {
          "type": "string",
          "format": "uuid",
          "description": "UUID for idempotent booking creation"
        }
      }
    },
    "instant": {
      "type": "boolean",
      "default": false,
      "description": "Create booking instantly without attendee selection (team event types only)"
    },
    "recurrenceCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 52,
      "description": "Number of occurrences for recurring bookings"
    },
    "seatReference": {
      "type": "string",
      "description": "Reference for seat assignment in multi-seat event types"
    }
  },
  "oneOf": [
    {
      "required": [
        "eventTypeId"
      ]
    },
    {
      "required": [
        "eventTypeSlug",
        "username"
      ]
    },
    {
      "required": [
        "eventTypeSlug",
        "organizationSlug"
      ]
    }
  ],
  "additionalProperties": false
}