{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DNS Check Response",
  "type": "object",
  "properties": {
    "domain": {"type": "string"},
    "expected_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "enum": ["A", "CNAME", "TXT"]},
          "name": {"type": "string"},
          "value": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["type", "name", "value", "description"]
      }
    },
    "common_issues": {"type": "array", "items": {"type": "string"}},
    "verification_url": {"type": "string"},
    "escalation_criteria": {"type": "string"},
    "reference_file": {"type": "string"}
  },
  "required": ["domain", "expected_records", "common_issues", "verification_url", "escalation_criteria", "reference_file"],
  "additionalProperties": false
}