{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DNS Check Request",
  "type": "object",
  "properties": {
    "domain": {
      "type": "string",
      "format": "hostname",
      "minLength": 1,
      "description": "Domain name to check (e.g., example.com)"
    }
  },
  "required": ["domain"],
  "additionalProperties": false
}