{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMS Debug Response",
  "type": "object",
  "properties": {
    "collection": {
      "type": "string"
    },
    "page_slug": {
      "type": "string"
    },
    "is_dynamic_item_page": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check": {"type": "string"},
          "status": {"type": "string", "enum": ["pass", "fail", "warning", "info"]},
          "details": {"type": "string"},
          "action": {"type": "string"}
        },
        "required": ["check", "status", "details", "action"]
      }
    },
    "reference_file": {
      "type": "string"
    },
    "next_steps": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "required": ["collection", "page_slug", "is_dynamic_item_page", "checks", "reference_file", "next_steps"],
  "additionalProperties": false
}