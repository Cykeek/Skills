{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Review Response",
  "type": "object",
  "required": ["design", "context", "goals", "review", "reference_files"],
  "properties": {
    "design": { "type": "string" },
    "context": { "type": "string" },
    "goals": { "type": "array", "items": { "type": "string" } },
    "review": {
      "type": "object",
      "required": ["overall_read", "what_is_working", "breakdowns", "recommendations", "open_questions", "principles_referenced"],
      "properties": {
        "overall_read": { "type": "string" },
        "what_is_working": { "type": "array", "items": { "type": "string" } },
        "breakdowns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["area", "issue", "severity"],
            "properties": {
              "area": { "type": "string", "enum": ["Problem/goal fit", "Flow/interaction", "Craft/hierarchy", "Trust/accessibility"] },
              "issue": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
            }
          }
        },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "principles_referenced": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reference_files": { "type": "array", "items": { "type": "string" } }
  }
}