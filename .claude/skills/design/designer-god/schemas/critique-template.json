{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Critique Template",
  "type": "object",
  "required": ["template_name", "structure", "principles", "example", "reference_file"],
  "properties": {
    "template_name": { "type": "string" },
    "structure": { "type": "array", "items": { "type": "string" } },
    "principles": { "type": "array", "items": { "type": "string" } },
    "example": {
      "type": "object",
      "required": ["overall_read", "what_is_working", "breakdowns", "recommendations", "open_questions", "principles_referenced"],
      "properties": {
        "overall_read": { "type": "string" },
        "what_is_working": { "type": "array", "items": { "type": "string" } },
        "breakdowns": { "type": "array", "items": { "type": "object", "required": ["area", "issue", "severity"], "properties": { "area": { "type": "string" }, "issue": { "type": "string" }, "severity": { "type": "string" } } } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "principles_referenced": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reference_file": { "type": "string" }
  }
}