{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-workflows.example.com/schemas/output-envelope.json",
  "title": "Agent Output Envelope",
  "description": "Standard envelope for agent-mode output",
  "type": "object",
  "required": ["timestamp", "format_version", "data"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of output generation"
    },
    "format_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Output format version (major.minor)"
    },
    "data": {
      "description": "Payload - structure depends on command/operation",
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "skill": { "type": "string", "default": "content-writer" },
        "command": { "type": "string" },
        "pipeline_stage": { "type": "string" },
        "brief_id": { "type": "string" },
        "execution_time_ms": { "type": "integer" }
      }
    }
  },
  "additionalProperties": false
}